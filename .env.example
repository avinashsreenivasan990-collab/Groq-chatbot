# ---- LLM Configuration ----
# Provider: "gemini", "openai", or "groq"
PROVIDER=groq

# API Key (get yours at https://console.groq.com/keys)
API_KEY=your_api_key_here

# Model Name
# Groq models:  llama-3.3-70b-versatile, llama-3.1-8b-instant, mixtral-8x7b-32768, gemma2-9b-it
# Gemini models: gemini-2.0-flash, gemini-1.5-pro
# OpenAI models: gpt-4o-mini, gpt-4o
MODEL_NAME=llama-3.3-70b-versatile

# Temperature (0.0 to 1.0)
TEMPERATURE=0.7
